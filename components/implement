    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Manrope:wght@300;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">

    <!-- GSAP for Advanced Animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <style>
        :root {
            --gold-gradient: linear-gradient(135deg, #bf953f, #fcf6ba, #b38728, #fbf5b7, #aa771c);
            --dark-bg: #050505;
        }

        body {
            background-color: var(--dark-bg);
            color: #ffffff;
            font-family: 'Manrope', sans-serif;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 {
            font-family: 'Playfair Display', serif;
        }

        .font-cinzel {
            font-family: 'Cinzel', serif;
        }

        /* Gold Text Effect */
        .text-gold {
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            color: transparent;
            background-size: 200% auto;
            animation: shine 4s linear infinite;
        }

        @keyframes shine {
            to {
                background-position: 200% center;
            }
        }

        /* Smooth Scrolling */
        html {
            scroll-behavior: smooth;
        }

        /* Parallax Container Styles */
        .parallax-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .parallax-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 120%;
            background-size: cover;
            background-position: center;
            opacity: 0.3;
            z-index: 0;
            will-change: transform;
            transition: transform 0.1s linear;
        }

        .glass-card {
            background: rgba(10, 10, 10, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 215, 0, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .step-number-outline {
            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
            color: transparent;
            position: absolute;
            z-index: -1;
            font-size: 15rem;
            line-height: 1;
            font-weight: 700;
            font-family: 'Cinzel', serif;
            opacity: 0.5;
            transition: all 0.5s ease;
        }
        
        @media (max-width: 768px) {
            .step-number-outline {
                font-size: 8rem;
                top: 0;
                right: 0;
            }
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #000; 
        }
        ::-webkit-scrollbar-thumb {
            background: #b38728; 
        }

        /* Button Hover Effect */
        .btn-luxury {
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .btn-luxury::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: 0.5s;
        }
        .btn-luxury:hover::before {
            left: 100%;
        }

        /* --- FLIP CARD STYLES --- */
        .perspective-1000 {
            perspective: 1000px;
        }
        
        .flip-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            text-align: center;
            transition: transform 0.8s;
            transform-style: preserve-3d;
        }
        
        .flip-card.flipped .flip-card-inner {
            transform: rotateY(180deg);
        }
        
        .flip-card-front, .flip-card-back {
            position: absolute;
            width: 100%;
            height: 100%;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            border-radius: 0.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        
        .flip-card-front {
            background: rgba(20, 20, 20, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .flip-card-back {
            background: #0a0a0a;
            border: 1px solid rgba(255, 215, 0, 0.5);
            transform: rotateY(180deg);
        }

        /* Tab Active State (Services) */
        .tab-btn.active {
            color: #b38728;
            border-bottom: 2px solid #b38728;
        }
        .tab-btn {
            transition: all 0.3s ease;
            border-bottom: 2px solid transparent;
        }
        .tab-btn:hover {
            color: #fcf6ba;
        }

        /* --- MODAL STYLES --- */
        .modal-overlay {
            opacity: 0;
            visibility: hidden;
            transition: all 0.4s ease;
        }
        .modal-overlay.open {
            opacity: 1;
            visibility: visible;
        }
        .modal-content {
            transform: scale(0.95);
            opacity: 0;
            transition: all 0.4s ease;
        }
        .modal-overlay.open .modal-content {
            transform: scale(1);
            opacity: 1;
        }
        
        .modal-tab-btn {
            padding-bottom: 0.5rem;
            color: #6b7280;
            font-family: 'Cinzel', serif;
            font-size: 0.9rem;
            transition: all 0.3s;
            border-bottom: 2px solid transparent;
        }
        .modal-tab-btn:hover {
            color: #bf953f;
        }
        .modal-tab-btn.active {
            color: #fcf6ba;
            border-bottom: 2px solid #bf953f;
        }

    </style>
</head>
