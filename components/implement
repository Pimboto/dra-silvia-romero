                        </div>
                        <div class="flex items-center gap-4 bg-white/5 p-3 rounded border border-white/10">
                            <div class="text-gold text-2xl">🎖️</div>
                            <div>
                                <h4 class="text-white font-bold text-sm">Certificación Board Internacional</h4>
                                <p class="text-xs text-gray-500">ISAPS & ASPS Member</p>
                            </div>
                        </div>
                    </div>
                `,
                image: "https://images.unsplash.com/photo-1579154204601-01588f351e67?q=80&w=2670&auto=format&fit=crop" // Awards/Certs image
            },
            {
                // Tab 2: Technology
                title: "Vanguardia Tecnológica",
                subtitle: "Equipos de Última Generación",
                text: `
                    <p class="mb-4 text-gray-300 font-light leading-relaxed">Utilizamos tecnología punta para garantizar procedimientos menos invasivos, recuperaciones más rápidas y resultados de alta precisión.</p>
                    <ul class="space-y-4 mt-4">
                        <li class="border-l-2 border-yellow-600 pl-4">
                            <strong class="text-white block font-cinzel">Vaser Lipo®</strong>
                            <span class="text-sm text-gray-400">Ultrasonido para definición muscular HD.</span>
                        </li>
                        <li class="border-l-2 border-yellow-600 pl-4">
                            <strong class="text-white block font-cinzel">Crisalix 3D</strong>
                            <span class="text-sm text-gray-400">Simulación virtual de resultados antes de operar.</span>
                        </li>
                        <li class="border-l-2 border-yellow-600 pl-4">
                            <strong class="text-white block font-cinzel">Renuvion</strong>
                            <span class="text-sm text-gray-400">Tensado de piel con tecnología de plasma.</span>
                        </li>
                    </ul>
                `,
                image: "https://images.unsplash.com/photo-1516549655169-df83a0774514?q=80&w=2670&auto=format&fit=crop" // Tech/Machine image
            }
        ];

        // --- MODAL FUNCTIONS ---
        const modal = document.getElementById('bioModal');
        const modalContent = document.getElementById('bioTextContent');
        const modalImage = document.getElementById('bioImage');
        const modalImageMob = document.getElementById('bioImageMobile');
        const bioTabs = document.querySelectorAll('.modal-tab-btn');

        function openModal() {
            modal.classList.add('open');
            switchBioTab(0); // Reset to first tab
        }

        function closeModal() {
            modal.classList.remove('open');
        }

        function switchBioTab(index) {
            // Update Tab Styles
            bioTabs.forEach((btn, i) => {
                if(i === index) btn.classList.add('active');
                else btn.classList.remove('active');
            });

            // Update Content with Fade Animation
            const data = bioData[index];
            
            // Fade Out Content
            gsap.to(modalContent, { opacity: 0, duration: 0.2, onComplete: () => {
                modalContent.innerHTML = `
                    <h3 class="text-3xl md:text-5xl font-playfair text-white mb-2">${data.title}</h3>
                    <h4 class="text-gold font-cinzel tracking-widest text-sm mb-8">${data.subtitle}</h4>
                    <div class="text-content">${data.text}</div>
                `;
                // Fade In Content
                gsap.to(modalContent, { opacity: 1, duration: 0.4 });
            }});

            // Fade Out Image
            gsap.to([modalImage, modalImageMob], { opacity: 0, duration: 0.2, onComplete: () => {
                modalImage.src = data.image;
                modalImageMob.src = data.image;
                // Fade In Image
                gsap.to([modalImage, modalImageMob], { opacity: 1, duration: 0.4 });
            }});
        }


        // --- RENDER FUNCTIONS FOR SERVICES (EXISTING) ---
        const tabsContainer = document.getElementById('tabs-container');
        const gridContainer = document.getElementById('procedures-grid');
        let activeTab = "CUERPO";

        function renderTabs() {
            tabsContainer.innerHTML = '';
            Object.keys(proceduresData).forEach(key => {
                const btn = document.createElement('button');
                btn.innerText = key;
                btn.className = `tab-btn text-sm md:text-lg uppercase tracking-widest font-bold px-4 py-2 cursor-pointer ${activeTab === key ? 'active' : 'text-gray-500'}`;
                btn.onclick = () => switchTab(key);
                tabsContainer.appendChild(btn);
            });
        }

        function renderCards(category) {
            // Fade out
            gsap.to(gridContainer, { opacity: 0, duration: 0.3, onComplete: () => {
                gridContainer.innerHTML = '';
                const items = proceduresData[category];
                
                items.forEach(item => {
                    const card = document.createElement('div');
                    card.className = "flip-card h-[400px] w-full perspective-1000 cursor-pointer group";
                    card.innerHTML = `
                        <div class="flip-card-inner">
                            <!-- Front -->
                            <div class="flip-card-front">
                                <h3 class="text-2xl font-playfair font-bold mb-4 text-white">${item.title}</h3>
                                <p class="text-gray-400 text-sm mb-8 px-4 font-light">${item.desc}</p>
                                <button class="btn-flip text-gold uppercase tracking-widest text-xs border-b border-yellow-600 pb-1 hover:text-white transition-colors" onclick="flipCard(this, true)">
                                    Ver Más +
                                </button>
                            </div>
                            <!-- Back -->
                            <div class="flip-card-back">
                                <h3 class="text-xl font-cinzel text-gold mb-4">${item.title}</h3>
                                <p class="text-gray-300 text-sm mb-6 leading-relaxed px-4">
                                    Procedimiento de alta precisión diseñado para resultados armónicos. 
                                    Incluye valoración inicial, quirófano certificado y seguimiento post-operatorio.
                                </p>
                                <button class="text-white bg-white/10 px-6 py-2 rounded-full text-xs uppercase tracking-widest hover:bg-white/20 transition-all" onclick="flipCard(this, false)">
                                    Volver
                                </button>
                            </div>
                        </div>
                    `;
                    gridContainer.appendChild(card);
                });

                // Fade In & Stagger items
                gsap.to(gridContainer, { opacity: 1, duration: 0.3 });
                gsap.from("#procedures-grid .flip-card", {
                    y: 30,
                    opacity: 0,
                    duration: 0.6,
                    stagger: 0.1,
                    ease: "power2.out"
                });
            }});
        }

        function switchTab(key) {
            activeTab = key;
            renderTabs();
            renderCards(key);
        }

        // --- FLIP LOGIC ---
        // Need to attach to window so HTML inline onclick works
        window.flipCard = function(btn, isFlipping) {
            event.stopPropagation(); // Stop bubbling
            const card = btn.closest('.flip-card');
            if(isFlipping) {
                card.classList.add('flipped');
            } else {
                card.classList.remove('flipped');
            }
        }

        // Initialize
        renderTabs();
        renderCards(activeTab);


        // --- EXISTING GSAP ANIMATIONS ---
        
        // 1. Parallax Effect
        gsap.utils.toArray('.parallax-section').forEach((section, i) => {
            const bg = section.querySelector('.parallax-bg');
            gsap.to(bg, {
                backgroundPosition: `50% ${innerHeight / 2}px`,
                ease: "none",
                scrollTrigger: {
                    trigger: section,
                    start: "top bottom", 
                    end: "bottom top",
                    scrub: true
                }
            });
        });

        // 2. Text Reveal
        gsap.utils.toArray('.gsap-reveal').forEach(element => {
            gsap.fromTo(element, 
                { y: 100, opacity: 0 },
                {
                    y: 0, opacity: 1, duration: 1.2, ease: "power3.out",
                    scrollTrigger: { trigger: element, start: "top 80%" }
                }
            );
        });

        // 3. Image Reveal
        gsap.utils.toArray('.gsap-image-reveal').forEach(element => {
            gsap.fromTo(element, 
                { scale: 0.8, opacity: 0, rotationY: 15 },
                {
                    scale: 1, opacity: 1, rotationY: 0, duration: 1.5, ease: "power2.out",
                    scrollTrigger: { trigger: element, start: "top 75%" }
                }
            );
        });

        // 4. Numbers
        gsap.utils.toArray('.step-number-outline').forEach(number => {
            gsap.to(number, {
                y: -50, ease: "none",
                scrollTrigger: { trigger: number, start: "top bottom", end: "bottom top", scrub: 2 }
            });
        });

        // Header Intro
        window.onload = () => {
            const tl = gsap.timeline();
            tl.from("header h1", { duration: 1.5, y: 50, opacity: 0, ease: "power4.out" })
              .from("header p", { duration: 1, opacity: 0 }, "-=1")
              .from("header .w-px", { duration: 1, height: 0, ease: "power2.inOut" }, "-=0.5");
        };

    </script>
</body>
</html>